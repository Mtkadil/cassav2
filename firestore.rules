rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper per validare la struttura dati
    function isValidSession(data) {
      return data.keys().hasAll(['date', 'counts', 'history', 'totalIncome', 'totalClients', 'updatedAt'])
        && data.date is string
        && data.counts is map
        && data.history is list
        && data.totalIncome is number
        && data.totalClients is number;
    }

    // Permettiamo l'accesso alla sessione condivisa senza login
    match /sessions/shared_session {
      allow read, write: if true; 
    }

    // Log storici (per l'archivio)
    match /logs/{logId} {
      allow read, write: if true;
    }
  }
}
